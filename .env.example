# Copia este archivo como .env y completa los valores reales
# NO subas .env al repositorio

# Servidor principal (MB51)
SQL_SERVER=tu-servidor.database.windows.net
SQL_DATABASE=nombre_base_datos
SQL_USERNAME=tu_usuario_sql
SQL_PASSWORD=tu_contraseña_sql

# Servidor secundario (Comercial)
SQL_COMERCIAL_SERVER=tu-servidor-comercial.database.windows.net
SQL_COMERCIAL_DATABASE=Comercial
SQL_COMERCIAL_USERNAME=tu_usuario_comercial
SQL_COMERCIAL_PASSWORD=tu_contraseña_comercial

# Servidor Colsap (ZFER/BOM)
SQL_COLSAP_SERVER=
SQL_COLSAP_DATABASE=
SQL_COLSAP_USERNAME=
SQL_COLSAP_PASSWORD=
